# --- Runtime ---------------------------------------------------------------
CORP_DATA_PATH=./data
CORP_LOG_LEVEL=INFO

# --- LLM routing (three tiers, one model per tier) -------------------------
# Each model is "local:<name>" (Ollama) or "cloud:<name>" (Anthropic).
#   trivial : very simple work            -> a tiny local model
#   normal  : everyday drafting            -> a cloud model
#   hard    : reasoning, code, strategy    -> a task-adapted top model
# Flip any prefix to keep that tier fully on-prem.
CORP_TRIVIAL_MODEL=local:gemma4:e4b
CORP_NORMAL_MODEL=cloud:claude-3-5-haiku-20241022
CORP_HARD_MODEL=cloud:claude-3-5-sonnet-20241022

# Local inference server and the embedding model used by the loop guard.
CORP_OLLAMA_URL=http://localhost:11434
CORP_EMBED_MODEL=nomic-embed-text
# Local model used as the fallback when a cloud tier is unreachable.
CORP_LOCAL_MODEL=qwen2.5:7b-instruct

# Cloud provider. Needed only for tiers/agents routed to "cloud:".
CORP_CLOUD_ENABLED=false
ANTHROPIC_API_KEY=

# Offline mode. When true, every LLM call is served by a deterministic mock,
# so the whole orchestrator runs with no network and no models installed.
CORP_LLM_MOCK=true

# --- Safety budgets --------------------------------------------------------
CORP_SESSION_TOKEN_BUDGET=100000
CORP_TOKENS_PER_MINUTE_LIMIT=10000
CORP_LOOP_SIMILARITY_THRESHOLD=0.95
CORP_MAX_IDENTICAL_TOOL_CALLS=2

# --- Human in the loop -----------------------------------------------------
# Tools listed here always pause for human approval before they execute.
CORP_HITL_TOOLS=send_financial_transaction,publish_production_code,deploy_site

# --- Real integrations (optional; leave unset and the tool uses its mock) ---
# Finance: live Stripe balance read. Use a restricted read-only key.
STRIPE_API_KEY=
# Sales site: the CTA button links to this Stripe Payment Link when set.
CORP_STRIPE_PAYMENT_LINK=
# Outreach: send the drafted opener over SMTP to a test/notification address.
CORP_SMTP_HOST=
CORP_SMTP_PORT=587
CORP_SMTP_USER=
CORP_SMTP_PASSWORD=
CORP_SMTP_FROM=
CORP_OUTREACH_TEST_TO=

# --- Deployment (providers tried in order; local is always available) -------
# Never tied to one host. Put an external provider first to publish there, with
# local kept last as the fallback (e.g. "netlify,local").
CORP_DEPLOY_PROVIDERS=local,netlify,s3,ssh
# local: copy the site into a self-hosted web root (nginx/Caddy) or a folder.
CORP_DEPLOY_LOCAL_DIR=
# Netlify (needs the netlify CLI on PATH).
NETLIFY_AUTH_TOKEN=
NETLIFY_SITE_ID=
# S3-compatible: AWS S3, self-hosted MinIO, or Cloudflare R2 (set the endpoint).
CORP_S3_BUCKET=
CORP_S3_ENDPOINT=
CORP_S3_REGION=
CORP_S3_KEY=
CORP_S3_SECRET=
# Self-hosted over SSH (rsync target).
CORP_DEPLOY_SSH_TARGET=

# --- Lead research (sources tried in order; local is always available) ------
# You are the operator: point CORP_LEADS_URL only at sources whose terms allow
# it, and mind data-protection law (GDPR). The browser source always runs
# headless and needs Playwright (pip install playwright; playwright install chromium).
CORP_LEAD_SOURCES=browser,local
CORP_LEADS_CSV=
CORP_LEADS_URL=
CORP_BROWSER_UA=

# --- Enrichment, deliverability, signals -----------------------------------
# Enrichment providers (local heuristic is always available).
CORP_ENRICHERS=local
CORP_ENRICH_DOMAIN=
# Outreach guard: a suppression list and a daily cap (the cap doubles as warmup).
CORP_SUPPRESSION_FILE=
CORP_OUTREACH_DAILY_CAP=0
CORP_OUTREACH_MAX_PER_RUN=20
# Buying-signal watcher (same headless browser plus local fallback pattern).
CORP_SIGNAL_SOURCES=browser,local
CORP_SIGNALS_FILE=
CORP_SIGNALS_URL=

# --- Backlog ---------------------------------------------------------------
# The CEO validates up to this many proposed tasks per review; the rest refused.
CORP_CEO_APPROVE_CAP=3
# Pull system: max in-progress + approved tasks per role (Kanban WIP limit).
CORP_WIP_LIMIT=4
