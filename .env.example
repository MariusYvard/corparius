# corparius settings.
#
# You do not need to edit this file. The operator console sets everything except
# the few bootstrap keys below, and stores it in data/corparius.sqlite. This file
# is only a convenient way to preset a value before the first launch.
#
# Precedence, first hit wins (see app/cfg.py):
#   1. the real process environment   (your shell, systemd, docker `environment:`)
#   2. settings saved from the console (data/corparius.sqlite)
#   3. this file
#   4. the default built into the code
# So the console overrides this file, and your shell overrides both. The console
# shows which layer answers for each field and marks the ones it cannot change.

# --- Bootstrap: must be readable before the store opens (restart to apply) ---
# Where the SQLite store and generated sites live. Left unset on purpose: the
# default is ./data from a source checkout, and a per-OS application-data folder
# in the packaged app. Uncomment and set an absolute path to point at an existing
# data folder (e.g. to migrate one between installs).
# CORP_DATA_PATH=./data
CORP_LOG_LEVEL=INFO
# Console address. Set a token to require X-Corp-Token on every call, reads
# included (needed if you expose the console beyond localhost).
CORP_UI_HOST=127.0.0.1
CORP_UI_PORT=8600
CORP_UI_TOKEN=
# Host names this console answers to, comma separated. Leave empty on a
# loopback bind: only localhost names are accepted and nothing needs setting.
# Behind a reverse proxy or in Docker, set it to the name you serve the console
# under - it is what stops a hostile domain from re-pointing itself at
# 127.0.0.1 and driving the console through your browser.
CORP_UI_ALLOWED_HOSTS=

# --- Offline by default -----------------------------------------------------
# true = every LLM call is a deterministic mock: no network, no models, no keys.
# Flip it from the console (Providers), or here, once you connect a model.
CORP_LLM_MOCK=true

# --- LLM routing (optional; all settable from the console) -------------------
# Each tier is "<target>:<name>". Targets: local (Ollama), cloud (Anthropic),
# claudecode (Claude Code CLI, subscription auth), or a free provider (groq,
# cerebras, openrouter, gemini, ...). The console's Providers tab does all of
# this with one-click Claude setup, a Test button per provider, Ollama pulls and
# local-server presets. Full registry, limits and keys: docs/llm-providers.md
CORP_TRIVIAL_MODEL=local:gemma4:e4b
CORP_NORMAL_MODEL=cloud:claude-3-5-haiku-20241022
CORP_HARD_MODEL=cloud:claude-3-5-sonnet-20241022
CORP_LOCAL_MODEL=qwen2.5:7b-instruct
CORP_OLLAMA_URL=http://localhost:11434

# Everything else — provider API keys, Stripe, SMTP and IMAP, deployment
# targets, lead sources, safety budgets, HITL tools — is set from the console
# and lives in the store. Set any of them here too if you prefer a file; the
# names are in docs/llm-providers.md and docs/console.md.
